# Liquid Life environment template
# Copy this file to .env in the repo root and fill in real values.
# The local startup scripts load this file for both Django and Next.js.

# Frontend
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Django core
SECRET_KEY=replace_with_a_long_random_secret
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
FRONTEND_BASE_URL=http://localhost:3000

# Database
# Preferred: use a full connection string.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/liquidlife

# Optional fallback database variables if DATABASE_URL is not set.
POSTGRES_DB=liquidlife
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Auth / admin
LIQUIDLIFE_ADMIN_USERNAME=LIQUIDLIFEADMIN
LIQUIDLIFE_ADMIN_PASSWORD=change_me_admin_password
GOOGLE_OAUTH_CLIENT_ID=

# AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=Liquid Life <no-reply@liquidlife.local>
EMAIL_HOST=localhost
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# CORS
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=

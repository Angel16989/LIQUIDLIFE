# Liquid Life environment template
# Copy this file to .env in the repo root and fill in real values.
# The local startup scripts load this file for both Django and Next.js.

# Frontend
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GITHUB_USERNAME=Angel16989
NEXT_PUBLIC_SITE_OWNER=Rasik N
NEXT_PUBLIC_LIQUIDLIFE_APP_URL=https://liquidlife.rasikn.com
PUBLIC_DOMAIN=your-domain.com
API_DOMAIN=api.your-domain.com
DEPLOY_MODE=cloudflare
CLOUDFLARE_TUNNEL_TOKEN=

# Docker/server note:
# If other devices will open the app through this machine, replace localhost/127.0.0.1
# with the server IP or domain before you build the frontend container.
# Example:
# NEXT_PUBLIC_API_URL=http://192.168.1.50:8000

# Django core
SECRET_KEY=replace_with_a_long_random_secret
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
FRONTEND_BASE_URL=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
USE_X_FORWARDED_HOST=False
USE_X_FORWARDED_PROTO=False
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
SECURE_CONTENT_TYPE_NOSNIFF=True
X_FRAME_OPTIONS=DENY

# Database
# Preferred: use a full connection string.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/liquidlife
DATABASE_CONN_MAX_AGE=0

# Optional fallback database variables if DATABASE_URL is not set.
POSTGRES_DB=liquidlife
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Auth / admin
LIQUIDLIFE_ADMIN_USERNAME=LIQUIDLIFEADMIN
LIQUIDLIFE_ADMIN_PASSWORD=change_me_admin_password
LIQUIDLIFE_ADMIN_NOTIFICATION_EMAILS=your-admin@gmail.com
GOOGLE_OAUTH_CLIENT_ID=

# AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=your-admin@gmail.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-admin@gmail.com
EMAIL_HOST_PASSWORD=your_gmail_app_password
EMAIL_USE_TLS=True
AUTHORIZATION_EMAIL_ACTION_MAX_AGE_SECONDS=604800
EMAIL_VERIFICATION_MAX_AGE_SECONDS=604800
ACCOUNT_VERIFICATION_REQUIRED=False
ACCOUNT_VERIFICATION_NOTICE_ENABLED=True

# Phone verification (Twilio Verify)
# Leave these blank if SMS is unavailable. Email verification still works.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Static / media storage
STATIC_ROOT=
MEDIA_ROOT=
MEDIA_URL=/media/

# CORS
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Production example overrides
# DEBUG=False
# NEXT_PUBLIC_API_URL=https://api.your-domain.com
# FRONTEND_BASE_URL=https://app.your-domain.com
# ALLOWED_HOSTS=api.your-domain.com,app.your-domain.com
# CORS_ALLOWED_ORIGINS=https://app.your-domain.com
# CSRF_TRUSTED_ORIGINS=https://app.your-domain.com

# Docker server example overrides
# NEXT_PUBLIC_API_URL=http://192.168.1.50:8000
# FRONTEND_BASE_URL=http://192.168.1.50:3000
# ALLOWED_HOSTS=192.168.1.50,localhost,127.0.0.1
# CORS_ALLOWED_ORIGINS=http://192.168.1.50:3000
# CSRF_TRUSTED_ORIGINS=http://192.168.1.50:3000
# DEPLOY_MODE=direct
# PUBLIC_DOMAIN=your-domain.com
# API_DOMAIN=api.your-domain.com
# ALLOWED_HOSTS=api.your-domain.com
# CSRF_TRUSTED_ORIGINS=https://app.your-domain.com
# USE_X_FORWARDED_HOST=True
# USE_X_FORWARDED_PROTO=True
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# CORS_ALLOWED_ORIGINS=https://app.your-domain.com
# DATABASE_CONN_MAX_AGE=60
# STATIC_ROOT=/var/data/liquidlife/staticfiles
# MEDIA_ROOT=/var/data/liquidlife/media

# Cloudflare Tunnel example
# DEPLOY_MODE=cloudflare
# NEXT_PUBLIC_API_URL=https://api.your-domain.com
# FRONTEND_BASE_URL=https://your-domain.com
# ALLOWED_HOSTS=your-domain.com,api.your-domain.com,localhost,127.0.0.1,backend
# CORS_ALLOWED_ORIGINS=https://your-domain.com
# CSRF_TRUSTED_ORIGINS=https://your-domain.com
# CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_from_cloudflare
